# Variáveis de ambiente — copie para .env e preencha

# Django
SECRET_KEY=troque-por-uma-chave-secreta-longa-e-aleatoria
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Banco de dados (padrão: SQLite — descomente para PostgreSQL)
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=monitor_fiscal
# DB_USER=postgres
# DB_PASSWORD=sua_senha
# DB_HOST=localhost
# DB_PORT=5432

# Chave de criptografia (Fernet/AES-256) para a senha do certificado.
# Gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

